# =====================================================================
# CHAT-BOT - EXEMPLO DE CONFIGURAÇÃO
# =====================================================================
# Copie este arquivo para `.env` no computador novo e preencha os valores.
# Nunca commite o `.env` real.

# WhatsApp Cloud API
# Instancia: Matriz
# Numero do bot: +55 48 99148-2618
WHATSAPP_TOKEN=COLOQUE_SEU_TOKEN_AQUI
# IMPORTANTE: este campo precisa do PHONE_NUMBER_ID da Meta (nao o numero de telefone)
WHATSAPP_PHONE_NUMBER_ID=COLOQUE_O_PHONE_NUMBER_ID_AQUI
# Opcional: ID numerico da conta WhatsApp Business (WABA) para listagem de numeros
# WHATSAPP_BUSINESS_ACCOUNT_ID=COLOQUE_A_WABA_ID_AQUI
# Opcional: outros números
# WHATSAPP_PHONE_NUMBER_ID_1=COLOQUE_AQUI
# WHATSAPP_PHONE_NUMBER_ID_2=COLOQUE_AQUI
# PHONE_NUMBER_ID_1=COLOQUE_AQUI
# PHONE_NUMBER_ID_2=COLOQUE_AQUI
# WHATSAPP_GRAPH_API_VERSION=v22.0

# Webhook
WEBHOOK_VERIFY_TOKEN=COLOQUE_UM_TOKEN_DE_VERIFICACAO_AQUI

# App
BOT_INSTANCE_NAME=MATRIZ
PORT=3001
NODE_ENV=development
NGROK_AUTOSTART=false

# Banco de dados
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres
# Opcional: fallback para ambientes onde o host principal nao resolve DNS
DATABASE_URL_POOLER=postgresql://usuario:senha@host-pooler:5432/postgres
DATABASE_URL_SESSION_POOLER=postgresql://usuario:senha@host-session-pooler:5432/postgres
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=COLOQUE_AQUI
SUPABASE_SERVICE_ROLE_KEY=COLOQUE_AQUI
DATABASE_SSL_DISABLE=false

# Opcional
# NGROK_AUTH_TOKEN=COLOQUE_AQUI
